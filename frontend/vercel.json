{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "viveretropea.it"
        }
      ],
      "destination": "https://www.viveretropea.it/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.viveretropea.com"
        }
      ],
      "destination": "https://www.viveretropea.it/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "viveretropea.com"
        }
      ],
      "destination": "https://www.viveretropea.it/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
